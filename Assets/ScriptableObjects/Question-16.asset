  m_Script: {fileID: 11500000, guid: b228a2a438c14f64e96b4dc91e8bdb3d, type: 3}
  m_Name: Question-16
  m_EditorClassIdentifier: Assembly-CSharp::Question
  HeaderLine: Which statement best reflects the clinical presentation of early gastric
    cancer?
  AsnwerSlot:
  - It almost always presents with severe abdominal pain
  - It is usually associated with overt bleeding
  - It may be asymptomatic or present with nonspecific dyspepsia
  - It typically presents with obstructive jaundice
  IsCorrectAnswer: 00000100
  Reference: "References: \u2022\tMaconi G, Manes G, Porro GB. Role of symptoms in
    diagnosis and outcome of gastric cancer. World J Gastroenterol. 2008;14(8):1149-1155.
    \u2022\tCorrea P. Gastric cancer: overview. Gastroenterol Clin North Am. 2013;42(2):211-217. "
